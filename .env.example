# Copy to backend/.env for local dev, or set these as env vars on the host.

# --- Anthropic (enrichment + chat) ---
# Get a key at https://console.anthropic.com. If left empty, the app uses MOCK
# enrichment/answers so you can test the whole pipeline without a key or cost.
ANTHROPIC_API_KEY=
OPUS_MODEL=claude-opus-4-8
SONNET_MODEL=claude-sonnet-4-6

# --- Auth ---
# Shared single-user token. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If empty, auth is DISABLED (local dev only — always set this in production).
CAPTURE_TOKEN=

# --- Storage / data ---
# Local dev: ./data. In Docker: /data (the mounted persistent volume).
DATA_DIR=./data
# Optional explicit DB URL; derived from DATA_DIR when unset.
# DATABASE_URL=sqlite+aiosqlite:////data/alvolo.db

# --- Worker ---
# WORKER_CONCURRENCY=2     # parallel Claude calls

# --- Audio (voice notes) ---
# Local speech-to-text via faster-whisper (no external service). Model size:
#   tiny | base | small | medium | large-v3  (bigger = better but slower).
# The model downloads on first use.
WHISPER_MODEL=base

# --- Web Push (notifications) ---
# Generate a key pair once:  npx web-push generate-vapid-keys
# Leave empty to disable push notifications (the app still works without them).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Deploy (docker compose) ---
# Host port published by docker compose (the container always listens on 8000).
# Point your reverse proxy at ${APP_BIND}:${APP_PORT}.
APP_PORT=8000
# Host interface the port binds to. Keep 127.0.0.1 if the reverse proxy runs on
# this same machine. If the proxy is on ANOTHER machine (e.g. Nginx Proxy Manager
# on the LAN), set the host's LAN IP (es. 192.168.40.13) or 0.0.0.0.
APP_BIND=127.0.0.1

# --- Misc ---
ENV=development
