# Copy to backend/.env for local dev, or set these as env vars on the host.

# --- Anthropic (enrichment) ---
# Get a key at https://console.anthropic.com. If left empty, the app uses MOCK
# enrichment so you can test the whole pipeline without a key or cost.
ANTHROPIC_API_KEY=
OPUS_MODEL=claude-opus-4-8
SONNET_MODEL=claude-sonnet-4-6

# --- Auth ---
# Shared single-user token. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If empty, auth is DISABLED (local dev only — always set this in production).
CAPTURE_TOKEN=

# --- Storage / data ---
# Local dev: ./data. On Railway: /data (the mounted persistent volume).
DATA_DIR=./data
# Optional explicit DB URL; derived from DATA_DIR when unset.
# DATABASE_URL=sqlite+aiosqlite:////data/alvolo.db

# --- Misc ---
ENV=development
